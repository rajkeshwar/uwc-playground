{
  "name": "uwc-playground",
  "description": "A CodePen-like live playground supporting **Lit**, **React**, **Vue 3**, and **Angular 18** with TypeScript + SCSS. Built with Lit 3, CodeMirror 6, Split.js, and `@web/dev-server`.",
  "main": "index.js",
  "version": "0.0.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "web-dev-server --node-resolve",
    "start:watch": "web-dev-server --node-resolve --watch",
    "test": "web-test-runner test/**/*.test.ts --node-resolve",
    "test:watch": "web-test-runner test/**/*.test.ts --node-resolve --watch",
    "build": "rollup -c rollup.config.mjs",
    "build:tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.3",
    "@open-wc/building-rollup": "^3.0.2",
    "@rollup/plugin-typescript": "^12.1.2",
    "@web/dev-server-esbuild": "^1.0.4",
    "codemirror": "^6.0.1",
    "lit": "^3.2.1",
    "rollup-plugin-copy": "^3.5.0",
    "split.js": "^1.6.5"
  },
  "devDependencies": {
    "@types/split.js": "^1.6.0",
    "@web/dev-server": "^0.4.6",
    "@web/dev-server-esbuild": "^1.0.2",
    "typescript": "^5.4.5"
  }
}
